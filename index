<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ระบบจัดการสต๊อก สาวน่านสปอร์ต</title>
    <!-- ใช้ Tailwind CSS สำหรับความสวยงาม -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- ใช้ FontAwesome สำหรับไอคอน -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { font-family: 'Sarabun', sans-serif; }
        .modal { transition: opacity 0.25s ease; }
        body.modal-active { overflow-x: hidden; overflow-y: hidden !important; }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-gray-100 h-screen flex overflow-hidden">

    <!-- Sidebar -->
    <aside class="w-64 bg-gray-900 text-white flex flex-col">
        <div class="p-6">
            <h1 class="text-2xl font-bold text-pink-400"><i class="fas fa-store mr-2"></i>สาวน่านสปอร์ต</h1>
            <p class="text-xs text-gray-400 mt-1">Stock Management System</p>
        </div>
        <nav class="flex-1 px-4 space-y-2 overflow-y-auto">
            <a href="#" onclick="changePage('dashboard')" id="nav-dashboard" class="nav-item block py-2.5 px-4 rounded transition duration-200 bg-blue-600 hover:bg-blue-700">
                <i class="fas fa-chart-line mr-2 w-5 text-center"></i> Dashboard ภาพรวม
            </a>
            <div class="text-xs text-gray-400 uppercase tracking-wider mt-6 mb-2 px-4">หมวดหมู่สินค้า</div>
            <a href="#" onclick="changePage('cat1')" id="nav-cat1" class="nav-item flex items-center py-2.5 px-4 rounded transition duration-200 hover:bg-gray-700">
                <i class="fas fa-pills mr-2 w-5 text-center text-blue-300"></i> <span id="label-cat1" class="truncate">โภชนาการ</span>
            </a>
            <a href="#" onclick="changePage('cat2')" id="nav-cat2" class="nav-item flex items-center py-2.5 px-4 rounded transition duration-200 hover:bg-gray-700">
                <i class="fas fa-tshirt mr-2 w-5 text-center text-orange-300"></i> <span id="label-cat2" class="truncate">เสื้อผ้าปั่นจักรยาน</span>
            </a>
            <a href="#" onclick="changePage('cat3')" id="nav-cat3" class="nav-item flex items-center py-2.5 px-4 rounded transition duration-200 hover:bg-gray-700">
                <i class="fas fa-running mr-2 w-5 text-center text-green-300"></i> <span id="label-cat3" class="truncate">สินค้า Partner</span>
            </a>
            <div class="text-xs text-gray-400 uppercase tracking-wider mt-6 mb-2 px-4">ระบบจัดการ</div>
            <a href="#" onclick="changePage('pos')" id="nav-pos" class="nav-item block py-2.5 px-4 rounded transition duration-200 hover:bg-gray-700 text-green-400">
                <i class="fas fa-file-upload mr-2 w-5 text-center"></i> อัพโหลดยอดขาย POS
            </a>
        </nav>
        <div class="p-4 text-xs text-gray-500 text-center border-t border-gray-800">
            อัพเดทล่าสุด: วันนี้
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col overflow-hidden">
        <!-- Header -->
        <header class="bg-white shadow px-6 py-4 flex justify-between items-center z-10">
            <h2 id="page-title" class="text-xl font-semibold text-gray-800">Dashboard</h2>
            <div class="flex items-center text-sm text-gray-600 bg-gray-100 py-1 px-3 rounded-full border">
                <i class="fas fa-user-circle text-xl mr-2 text-pink-500"></i> พนักงานขาย (สาวน่านสปอร์ต)
            </div>
        </header>

        <!-- Dynamic Content Area -->
        <div id="content-area" class="flex-1 overflow-x-hidden overflow-y-auto bg-gray-50 p-6">
            <!-- Content will be injected here by JS -->
        </div>
    </main>

    <!-- ================= MODALS ================= -->

    <!-- 1. Edit Stock Modal -->
    <div id="editModal" class="modal opacity-0 pointer-events-none fixed w-full h-full top-0 left-0 flex items-center justify-center z-50">
        <div class="modal-overlay absolute w-full h-full bg-gray-900 opacity-50" onclick="closeModal('editModal')"></div>
        <div class="modal-container bg-white w-11/12 md:max-w-md mx-auto rounded-lg shadow-xl z-50 overflow-y-auto transform transition-all">
            <div class="modal-content py-4 text-left px-6">
                <div class="flex justify-between items-center pb-3 border-b">
                    <p class="text-xl font-bold text-gray-800">แก้ไขจำนวนสต๊อก</p>
                    <div class="modal-close cursor-pointer z-50 p-2" onclick="closeModal('editModal')">
                        <i class="fas fa-times text-gray-400 hover:text-red-500"></i>
                    </div>
                </div>
                <div class="my-5">
                    <p id="edit-item-name" class="text-gray-700 mb-4 font-semibold bg-gray-100 p-2 rounded"></p>
                    <label class="block text-gray-700 text-sm font-bold mb-2">จำนวนคงเหลือในสต๊อก (อัพเดทใหม่):</label>
                    <input type="number" id="edit-item-stock" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                    <input type="hidden" id="edit-item-id">
                </div>
                <div class="flex justify-end pt-2 border-t mt-4 pt-4">
                    <button onclick="closeModal('editModal')" class="px-4 py-2 bg-white border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 mr-2 transition">ยกเลิก</button>
                    <button onclick="saveStockEdit()" class="px-4 py-2 bg-blue-600 rounded-lg text-white hover:bg-blue-700 transition shadow">บันทึก</button>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. Add New Product Modal -->
    <div id="addProductModal" class="modal opacity-0 pointer-events-none fixed w-full h-full top-0 left-0 flex items-center justify-center z-50">
        <div class="modal-overlay absolute w-full h-full bg-gray-900 opacity-50" onclick="closeModal('addProductModal')"></div>
        <div class="modal-container bg-white w-11/12 md:max-w-xl mx-auto rounded-lg shadow-xl z-50 overflow-y-auto transform transition-all">
            <div class="modal-content py-4 text-left px-6">
                <div class="flex justify-between items-center pb-3 border-b">
                    <p class="text-xl font-bold text-gray-800"><i class="fas fa-plus-circle text-green-500 mr-2"></i>เพิ่มสินค้าใหม่</p>
                    <div class="modal-close cursor-pointer z-50 p-2" onclick="closeModal('addProductModal')">
                        <i class="fas fa-times text-gray-400 hover:text-red-500"></i>
                    </div>
                </div>
                <div class="my-4 grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="col-span-1 md:col-span-2">
                        <label class="block text-gray-700 text-sm font-bold mb-2">ชื่อสินค้า <span class="text-red-500">*</span></label>
                        <input type="text" id="add-item-name" placeholder="เช่น กางเกงปั่นจักรยานสีดำ M" class="shadow-sm border rounded w-full py-2 px-3 text-gray-700 focus:outline-none focus:ring-2 focus:ring-green-500">
                    </div>
                    <div>
                        <label class="block text-gray-700 text-sm font-bold mb-2">หมวดหมู่</label>
                        <select id="add-item-cat" class="shadow-sm border rounded w-full py-2 px-3 text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-green-500">
                            <!-- Options will be populated dynamically -->
                        </select>
                    </div>
                    <div>
                        <label class="block text-gray-700 text-sm font-bold mb-2">สต๊อกเริ่มต้น <span class="text-red-500">*</span></label>
                        <input type="number" id="add-item-stock" value="0" min="0" class="shadow-sm border rounded w-full py-2 px-3 text-gray-700 focus:outline-none focus:ring-2 focus:ring-green-500">
                    </div>
                    <div>
                        <label class="block text-gray-700 text-sm font-bold mb-2">ราคาต้นทุน (บาท)</label>
                        <input type="number" id="add-item-cost" value="0" min="0" class="shadow-sm border rounded w-full py-2 px-3 text-gray-700 focus:outline-none focus:ring-2 focus:ring-green-500">
                    </div>
                    <div>
                        <label class="block text-gray-700 text-sm font-bold mb-2">ราคาขาย (บาท) <span class="text-red-500">*</span></label>
                        <input type="number" id="add-item-price" value="0" min="0" class="shadow-sm border rounded w-full py-2 px-3 text-gray-700 focus:outline-none focus:ring-2 focus:ring-green-500">
                    </div>
                    <div class="col-span-1 md:col-span-2">
                        <label class="block text-gray-700 text-sm font-bold mb-2">ลิงก์รูปภาพ (ถ้ามี)</label>
                        <input type="text" id="add-item-image" placeholder="https://..." class="shadow-sm border rounded w-full py-2 px-3 text-gray-700 focus:outline-none focus:ring-2 focus:ring-green-500">
                        <p class="text-xs text-gray-400 mt-1">เว้นว่างไว้ระบบจะใส่รูปเริ่มต้นให้</p>
                    </div>
                </div>
                <div class="flex justify-end pt-2 border-t mt-4 pt-4">
                    <button onclick="closeModal('addProductModal')" class="px-4 py-2 bg-white border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 mr-2 transition">ยกเลิก</button>
                    <button onclick="saveNewProduct()" class="px-4 py-2 bg-green-600 rounded-lg text-white hover:bg-green-700 transition shadow"><i class="fas fa-save mr-2"></i>บันทึกสินค้าใหม่</button>
                </div>
            </div>
        </div>
    </div>

    <!-- 3. Edit Category Name Modal -->
    <div id="editCatModal" class="modal opacity-0 pointer-events-none fixed w-full h-full top-0 left-0 flex items-center justify-center z-50">
        <div class="modal-overlay absolute w-full h-full bg-gray-900 opacity-50" onclick="closeModal('editCatModal')"></div>
        <div class="modal-container bg-white w-11/12 md:max-w-sm mx-auto rounded-lg shadow-xl z-50 overflow-y-auto transform transition-all">
            <div class="modal-content py-4 text-left px-6">
                <div class="flex justify-between items-center pb-3 border-b">
                    <p class="text-xl font-bold text-gray-800">เปลี่ยนชื่อหมวดหมู่</p>
                    <div class="modal-close cursor-pointer z-50 p-2" onclick="closeModal('editCatModal')">
                        <i class="fas fa-times text-gray-400 hover:text-red-500"></i>
                    </div>
                </div>
                <div class="my-5">
                    <label class="block text-gray-700 text-sm font-bold mb-2">ชื่อหมวดหมู่ใหม่:</label>
                    <input type="text" id="edit-cat-name-input" class="shadow-sm border rounded w-full py-2 px-3 text-gray-700 focus:outline-none focus:ring-2 focus:ring-orange-500">
                    <input type="hidden" id="edit-cat-id-input">
                </div>
                <div class="flex justify-end pt-2 border-t mt-4 pt-4">
                    <button onclick="closeModal('editCatModal')" class="px-4 py-2 bg-white border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 mr-2 transition">ยกเลิก</button>
                    <button onclick="saveCategoryName()" class="px-4 py-2 bg-orange-500 rounded-lg text-white hover:bg-orange-600 transition shadow">บันทึก</button>
                </div>
            </div>
        </div>
    </div>

    <!-- 4. POS Confirmation Modal -->
    <div id="posModal" class="modal opacity-0 pointer-events-none fixed w-full h-full top-0 left-0 flex items-center justify-center z-50">
        <div class="modal-overlay absolute w-full h-full bg-gray-900 opacity-50" onclick="closeModal('posModal')"></div>
        <div class="modal-container bg-white w-11/12 md:max-w-2xl mx-auto rounded-lg shadow-xl z-50 overflow-y-auto transform transition-all">
            <div class="modal-content py-4 text-left px-6">
                <div class="flex justify-between items-center pb-3 border-b">
                    <p class="text-2xl font-bold text-green-600"><i class="fas fa-check-circle mr-2"></i>ยืนยันการตัดสต๊อก</p>
                    <div class="modal-close cursor-pointer z-50 p-2" onclick="closeModal('posModal')">
                        <i class="fas fa-times text-gray-500 hover:text-red-500"></i>
                    </div>
                </div>
                <div class="my-4">
                    <p class="mb-2 text-gray-600">กรุณาตรวจสอบรายการยอดขายที่ระบบวิเคราะห์ได้ ก่อนทำการตัดสต๊อก</p>
                    <div class="bg-gray-50 p-4 rounded border max-h-64 overflow-y-auto" id="pos-summary-list">
                        <!-- POS items will be injected here -->
                    </div>
                    <div id="pos-error-msg" class="text-red-500 text-sm mt-2 hidden bg-red-50 p-3 rounded border border-red-200"></div>
                </div>
                <div class="flex justify-end pt-2 border-t mt-4 pt-4">
                    <button onclick="closeModal('posModal')" class="px-4 py-2 bg-white border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 mr-2 transition">ยกเลิก</button>
                    <button onclick="confirmPOSDeduction()" class="px-4 py-2 bg-green-600 rounded-lg text-white hover:bg-green-700 transition shadow"><i class="fas fa-save mr-2"></i>ยืนยันและตัดสต๊อก</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // --- 1. DATA STRUCTURES ---

        // Object เก็บชื่อหมวดหมู่ (เพื่อให้แก้ไขได้)
        let categories = {
            'cat1': 'โภชนาการ (Amino, Mileage)',
            'cat2': 'เสื้อผ้าปั่นจักรยาน',
            'cat3': 'สินค้า Partner / Decathlon'
        };

        // ข้อมูลสินค้าจำลอง
        let inventory = [
            // หมวดที่ 1
            { id: '1-1', cat: 'cat1', name: 'Amino Vital Blue pouch 100 g', cost: 52.5, price: 75, stock: 0, image: 'https://via.placeholder.com/50/3B82F6/ffffff?text=Blue' },
            { id: '1-2', cat: 'cat1', name: 'Amino Vital Fit 90 g', cost: 31.5, price: 45, stock: 30, image: 'https://via.placeholder.com/50/EF4444/ffffff?text=Fit' },
            { id: '1-3', cat: 'cat1', name: 'Amino Vital Red shot (รสแอปเปิ้ล) 45 g', cost: 42, price: 60, stock: 114, image: 'https://via.placeholder.com/50/EF4444/ffffff?text=Apple' },
            { id: '1-4', cat: 'cat1', name: 'Amino Vital Red shot (รสบ๊วย) 45 g', cost: 42, price: 60, stock: 0, image: 'https://via.placeholder.com/50/EF4444/ffffff?text=Plum' },
            { id: '1-5', cat: 'cat1', name: 'Mileage 25 Boost Hydrogel', cost: 88.78, price: 95, stock: 108, image: 'https://via.placeholder.com/50/1F2937/ffffff?text=Mileage' },
            { id: '1-6', cat: 'cat1', name: '40 Endure Drink Mix Citrus', cost: 88.78, price: 95, stock: 20, image: 'https://via.placeholder.com/50/F59E0B/ffffff?text=Endure' },
            { id: '1-7', cat: 'cat1', name: '250 Salt+ Electrolyte Capsule', cost: 233.64, price: 250, stock: 2, image: 'https://via.placeholder.com/50/8B5CF6/ffffff?text=Salt' },
            // หมวดที่ 2
            { id: '2-1', cat: 'cat2', name: 'กางเกง Deez สีเทา XS', cost: 1350, price: 1850, stock: 1, image: 'https://via.placeholder.com/50/9CA3AF/ffffff?text=Pants' },
            { id: '2-2', cat: 'cat2', name: 'กางเกง Deez สีครีม S', cost: 1350, price: 1850, stock: 1, image: 'https://via.placeholder.com/50/FDE68A/000000?text=Pants' },
            { id: '2-3', cat: 'cat2', name: 'กางเกง Deez สีกรม S', cost: 1350, price: 1850, stock: 0, image: 'https://via.placeholder.com/50/1E3A8A/ffffff?text=Pants' },
            { id: '2-4', cat: 'cat2', name: 'เสื้อ Strong สีดำ L', cost: 1650, price: 2490, stock: 5, image: 'https://via.placeholder.com/50/000000/ffffff?text=Shirt' },
            { id: '2-5', cat: 'cat2', name: 'เสื้อ Strong สีเทาเข้ม L', cost: 1650, price: 2490, stock: 2, image: 'https://via.placeholder.com/50/4B5563/ffffff?text=Shirt' },
            { id: '2-6', cat: 'cat2', name: 'กางเกงปั่นจักรยาน', cost: 150, price: 340, stock: 10, image: 'https://via.placeholder.com/50/9CA3AF/ffffff?text=Pants' },
            { id: '2-7', cat: 'cat2', name: 'ถุงเท้า', cost: 40, price: 90, stock: 25, image: 'https://via.placeholder.com/50/FDE68A/000000?text=Socks' },
            { id: '2-8', cat: 'cat2', name: 'หมวก', cost: 80, price: 170, stock: 12, image: 'https://via.placeholder.com/50/1E3A8A/ffffff?text=Hat' },
            // หมวดที่ 3
            { id: '3-1', cat: 'cat3', name: 'MH500 BLACK C3', cost: 200, price: 300, stock: 10, image: 'https://via.placeholder.com/50/000000/ffffff?text=Glasses' },
            { id: '3-2', cat: 'cat3', name: '1PG 100 LILA SKIRT (4323890)', cost: 250, price: 350, stock: 8, image: 'https://via.placeholder.com/50/8B5CF6/ffffff?text=Skirt' },
            { id: '3-3', cat: 'cat3', name: '1PG 100 LILA SKIRT (4323888)', cost: 250, price: 350, stock: 2, image: 'https://via.placeholder.com/50/8B5CF6/ffffff?text=Skirt' },
            { id: '3-4', cat: 'cat3', name: '1PG 100 VEGA SKIRT (4103725)', cost: 150, price: 230, stock: 15, image: 'https://via.placeholder.com/50/EC4899/ffffff?text=Skirt' },
        ];

        let weeklySales = [
            { id: '1-3', qty: 28 }, { id: '1-5', qty: 15 }, { id: '1-2', qty: 10 },
            { id: '2-4', qty: 5 }, { id: '2-1', qty: 2 }, { id: '2-5', qty: 1 },
            { id: '3-4', qty: 12 }, { id: '3-1', qty: 8 }, { id: '3-2', qty: 4 }
        ];

        let pendingPOSData = [];
        let currentActivePage = 'dashboard';

        // --- 2. CORE & NAVIGATION ---

        function updateSidebarCatNames() {
            document.getElementById('label-cat1').innerText = categories['cat1'];
            document.getElementById('label-cat2').innerText = categories['cat2'];
            document.getElementById('label-cat3').innerText = categories['cat3'];
        }

        function changePage(page) {
            currentActivePage = page;
            
            // Update Active Nav Style
            document.querySelectorAll('.nav-item').forEach(el => {
                el.classList.remove('bg-blue-600', 'text-white');
                if(!el.classList.contains('text-green-400')) el.classList.remove('text-green-400');
                if(!el.id.includes('pos')) el.classList.add('hover:bg-gray-700'); // reset hover
            });
            
            let navId = `nav-${page}`;
            if(document.getElementById(navId)) {
                if(page === 'pos') {
                    document.getElementById(navId).classList.add('bg-gray-800', 'text-green-400');
                    document.getElementById(navId).classList.remove('hover:bg-gray-700');
                } else {
                    document.getElementById(navId).classList.add('bg-blue-600', 'text-white');
                    document.getElementById(navId).classList.remove('hover:bg-gray-700');
                }
            }

            const contentArea = document.getElementById('content-area');
            const pageTitle = document.getElementById('page-title');

            if (page === 'dashboard') {
                pageTitle.innerText = "Dashboard ภาพรวมร้าน สาวน่านสปอร์ต";
                renderDashboard(contentArea);
            } else if (page.startsWith('cat')) {
                pageTitle.innerText = `สต๊อกสินค้า: ${categories[page]}`;
                renderCategory(contentArea, page);
            } else if (page === 'pos') {
                pageTitle.innerText = "อัพโหลดไฟล์ยอดขายจากระบบ POS";
                renderPOSUpload(contentArea);
            }
        }

        // --- 3. RENDER FUNCTIONS ---

        function renderDashboard(container) {
            const lowStockItems = inventory.filter(item => item.stock < 3);
            
            let html = `
                <!-- สรุปแจ้งเตือน -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                    <div class="bg-white rounded-xl shadow-sm p-6 border-l-4 border-red-500 flex items-center">
                        <div class="p-4 rounded-full bg-red-50 text-red-500 mr-4">
                            <i class="fas fa-exclamation-triangle text-3xl"></i>
                        </div>
                        <div>
                            <p class="mb-1 text-sm font-semibold text-gray-500 uppercase tracking-wide">สินค้าใกล้หมด / หมดสต๊อก</p>
                            <p class="text-3xl font-bold text-gray-800">${lowStockItems.length} <span class="text-base font-normal text-gray-500">รายการ (< 3 ชิ้น)</span></p>
                        </div>
                    </div>
                    <div class="bg-white rounded-xl shadow-sm p-6 border-l-4 border-blue-500 flex items-center">
                        <div class="p-4 rounded-full bg-blue-50 text-blue-500 mr-4">
                            <i class="fas fa-boxes text-3xl"></i>
                        </div>
                        <div>
                            <p class="mb-1 text-sm font-semibold text-gray-500 uppercase tracking-wide">สินค้าทั้งหมดในระบบ</p>
                            <p class="text-3xl font-bold text-gray-800">${inventory.length} <span class="text-base font-normal text-gray-500">รายการ</span></p>
                        </div>
                    </div>
                </div>

                <h3 class="text-lg font-bold text-gray-800 mb-4 flex items-center"><i class="fas fa-trophy text-yellow-500 mr-2 text-xl"></i> สินค้าขายดีประจำสัปดาห์</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                    ${renderTopSellerCard(categories['cat1'], 'cat1', 'border-blue-400')}
                    ${renderTopSellerCard(categories['cat2'], 'cat2', 'border-orange-400')}
                    ${renderTopSellerCard(categories['cat3'], 'cat3', 'border-green-400')}
                </div>

                <h3 class="text-lg font-bold text-red-600 mb-4 flex items-center"><i class="fas fa-clipboard-list mr-2 text-xl"></i> รายการที่พนักงานต้องสั่งเพิ่มด่วน</h3>
                <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                    <table class="min-w-full leading-normal">
