        // --- 4. MODALS & ACTIONS LOGIC ---

        function closeModal(modalId) {
            document.getElementById(modalId).classList.add('opacity-0', 'pointer-events-none');
            document.body.classList.remove('modal-active');
        }

        // --- แก้ไขสต๊อก (Manual) ---
        function openEditModal(itemId) {
            const item = inventory.find(i => i.id === itemId);
            if(item) {
                document.getElementById('edit-item-name').innerText = item.name;
                document.getElementById('edit-item-stock').value = item.stock;
                document.getElementById('edit-item-id').value = item.id;
                
                document.getElementById('editModal').classList.remove('opacity-0', 'pointer-events-none');
                document.body.classList.add('modal-active');
            }
        }

        function saveStockEdit() {
            const id = document.getElementById('edit-item-id').value;
            const newStock = parseInt(document.getElementById('edit-item-stock').value);
            
            if(!isNaN(newStock) && newStock >= 0) {
                const itemIndex = inventory.findIndex(i => i.id === id);
                if(itemIndex > -1) {
                    inventory[itemIndex].stock = newStock;
                    closeModal('editModal');
                    if(currentActivePage === inventory[itemIndex].cat) {
                        changePage(currentActivePage); // Reload current page
                    }
                }
            } else {
                alert('กรุณาใส่ตัวเลขจำนวนเต็มที่ถูกต้อง (0 ขึ้นไป)');
            }
        }

        // --- เพิ่มสินค้าใหม่ ---
        function openAddModal(defaultCatId) {
            // เคลียร์ฟอร์ม
            document.getElementById('add-item-name').value = '';
            document.getElementById('add-item-stock').value = '0';
            document.getElementById('add-item-cost').value = '0';
            document.getElementById('add-item-price').value = '0';
            document.getElementById('add-item-image').value = '';

            // สร้าง Options สำหรับ Dropdown หมวดหมู่
            const selectCat = document.getElementById('add-item-cat');
            selectCat.innerHTML = '';
            for (const [key, value] of Object.entries(categories)) {
                let selected = (key === defaultCatId) ? 'selected' : '';
                selectCat.innerHTML += `<option value="${key}" ${selected}>${value}</option>`;
            }

            document.getElementById('addProductModal').classList.remove('opacity-0', 'pointer-events-none');
            document.body.classList.add('modal-active');
        }

        function saveNewProduct() {
            const name = document.getElementById('add-item-name').value.trim();
            const cat = document.getElementById('add-item-cat').value;
            const stock = parseInt(document.getElementById('add-item-stock').value);
            const cost = parseFloat(document.getElementById('add-item-cost').value);
            const price = parseFloat(document.getElementById('add-item-price').value);
            let image = document.getElementById('add-item-image').value.trim();

            // Validation พื้นฐาน
            if(!name) { alert('กรุณาระบุชื่อสินค้า'); return; }
            if(isNaN(stock) || stock < 0) { alert('สต๊อกต้องเป็นตัวเลข 0 ขึ้นไป'); return; }
            if(isNaN(price) || price < 0) { alert('กรุณาระบุราคาขายที่ถูกต้อง'); return; }

            // กำหนดรูป Default ถ้าไม่ใส่ลิงก์
            if(!image) {
                // สร้างรูป placeholder แบบสุ่มสี
                const randomColor = Math.floor(Math.random()*16777215).toString(16);
                image = `https://via.placeholder.com/50/${randomColor}/ffffff?text=New`;
            }

            // สร้าง ID ใหม่ (ใช้ timestamp ให้ไม่ซ้ำ)
            const newId = 'new-' + Date.now().toString().slice(-6);

            const newItem = {
                id: newId,
                cat: cat,
                name: name,
                cost: isNaN(cost) ? 0 : cost,
                price: price,
                stock: stock,
                image: image
            };

            inventory.push(newItem);
            closeModal('addProductModal');
            
            // นำผู้ใช้ไปยังหน้าหมวดหมู่ของสินค้าที่เพิ่งเพิ่ม
            changePage(cat);
        }

